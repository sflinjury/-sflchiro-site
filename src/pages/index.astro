---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Nav />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg-wave"></div>
    <div class="hero-inner">
      <div class="hero-left">
        <div class="hero-eyebrow">Chiropractic Care · Two South Florida Locations</div>
        <h1 class="hero-headline">

          <span class="hero-accent">In Pain?</span><br/>
          Get Evaluated.
        </h1>
        <p class="hero-tagline-badge">RECOVER. RESTORE. LIVE. · AFTER-HOURS CALLS ANSWERED</p>
        <p class="hero-sub">
          Dr. Brian Wilner, D.C. has treated thousands of accident and injury patients across South Florida since 2000. We answer after-hours calls, offer same-day appointments, and accept PIP insurance. When you're hurt, you shouldn't have to wait.
        </p>
        <div class="hero-actions">
          <a href="tel:+19546066325" class="btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.59 1.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6.09 6.09l1.18-1.18a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Tamarac — (954) 606-NECK
          </a>
          <a href="tel:+17723332648" class="btn-ghost">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.59 1.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6.09 6.09l1.18-1.18a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Port Saint Lucie — (772) 333-2648
          </a>
        </div>
        <div class="hero-trust">
          <div class="trust-item">
            <strong>Same-Day</strong>
            <span>Appointments Available</span>
          </div>
          <div class="trust-divider"></div>
          <div class="trust-item">
            <strong>PIP</strong>
            <span>Insurance Accepted</span>
          </div>
          <div class="trust-divider"></div>
          
        </div>
      </div>
      <div class="hero-right">
        <div class="hero-card">
          <div class="hero-card-header">
            <div class="hero-card-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <span>Accepted Billing & Coverage</span>
          </div>
          <ul class="hero-accepts">
            <li>PIP Insurance (Florida No-Fault)</li>
            <li>Major Auto Insurance Carriers</li>
            <li>Attorney-Coordinated Cases</li>
          </ul>
          <div class="hero-card-divider"></div>
          <p class="hero-card-note">
            Hurt in an accident? Florida PIP benefits may require evaluation within 14 days. Call now — we answer after hours.
          </p>
          <a href="tel:+19546066325" class="hero-card-cta">
            Schedule an Evaluation
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- PIP NOTICE BANNER -->
  <section class="urgency-bar">
    <div class="urgency-inner">
      <span class="urgency-icon">ℹ</span>
      <p><strong>Florida PIP Notice:</strong> Under §627.736 F.S., PIP benefits may require initial treatment within 14 days of your accident. This is an informational notice, not legal advice — consult your attorney or insurer for your specific coverage.</p>
    </div>
  </section>


  <!-- STATS BAR -->
  <section class="stats-bar">
    <div class="stats-inner">
      <div class="stat-item">
        <div class="stat-number">14</div>
        <div class="stat-label">Days to preserve your PIP rights under Florida law</div>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <div class="stat-number">2</div>
        <div class="stat-label">Clinic locations serving Broward and St. Lucie County</div>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <div class="stat-number">24/7</div>
        <div class="stat-label">After-hours calls answered — we're here when you need us</div>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <div class="stat-number">PIP</div>
        <div class="stat-label">Florida no-fault insurance accepted at both locations</div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="section" id="services">
    <div class="section-inner">
      <div class="section-header reveal">
        <div class="eyebrow">Chiropractic Services</div>
        <h2>26 years treating South Florida.<br/>Same care. Same number. Call anytime.</h2>
        <p class="section-sub">Whether you were hurt in a car accident, slipped and fell, sustained a sports injury, or have been living with chronic back or neck pain — South Florida Injury Centers provides comprehensive chiropractic evaluation and treatment at two locations across South Florida. Services are rendered by licensed chiropractic physicians.</p>
      </div>
      <div class="services-grid">
      <p class="services-disclaimer">South Florida Injury Centers is a chiropractic medicine practice. Services are provided by licensed chiropractic physicians. We are not licensed as medical doctors in the State of Florida.</p>
    </div>
  </section>



  <!-- INLINE CTA STRIP -->
  <section class="cta-strip">
    <div class="cta-strip-inner">
      <div class="cta-strip-text">
        <strong>We answer after-hours calls. Call now.</strong>
        <span>Same-day appointments available. PIP insurance accepted. Licensed in Florida since 2000.</span>
      </div>
      <div class="cta-strip-actions">
        <a href="tel:+19546066325" class="btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.59 1.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6.09 6.09l1.18-1.18a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Tamarac (954) 606-NECK
        </a>
        <a href="tel:+17723332648" class="btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.59 1.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6.09 6.09l1.18-1.18a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Port Saint Lucie (772) 333-2648
        </a>
      </div>
    </div>
  </section>

  <!-- WHY SFIC -->
  <section class="section why-section">
    <div class="section-inner">
      <div class="why-grid">
        <div class="why-text reveal">
          <div class="eyebrow">Why Patients Choose SFIC</div>
          <h2>You call. We answer.<br/>Day or night.</h2>
          <p>Most clinics let calls go to voicemail after 5pm. We don't. Dr. Wilner has been treating injured patients since 2000 — that's 26 years — and knows that accidents happen at 7pm on a Friday just as often as they do on a Tuesday morning. Call either location — someone will answer.</p>
          <ul class="why-list">
            <li>
              <div class="why-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <strong>We answer after-hours calls</strong>
                <span>Injured at night or on the weekend? Call us. Someone will answer.</span>
              </div>
            </li>
            <li>
              <div class="why-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <strong>Licensed in Florida since 2000</strong>
                <span>Dr. Wilner has treated thousands of accident patients across South Florida over 26 years.</span>
              </div>
            </li>
            <li>
              <div class="why-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <strong>Same-day appointments</strong>
                <span>You shouldn't have to wait a week to be seen after an accident. Call and we'll get you in.</span>
              </div>
            </li>
            <li>
              <div class="why-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <strong>We handle the paperwork</strong>
                <span>Records requests, PIP billing, attorney coordination — we deal with it so you don't have to.</span>
              </div>
            </li>
          </ul>
        </div>
        <div class="why-visual reveal">
          <div class="visual-card-stack">
            <div class="visual-card vc-top">
              <div class="vc-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/><path d="M7 8h2"/><path d="M7 12h2"/><path d="M11 8h6"/><path d="M11 12h6"/></svg>
              </div>
              <div class="vc-content">
                <div class="vc-label">Diagnostic Report</div>
                <div class="vc-sub">On-site X-ray (Tamarac) · Spinal Analysis · Clinical Findings</div>
                <div class="vc-bar"><div class="vc-bar-fill" style="width:92%"></div></div>
                <div class="vc-bar-label">Objective. Quantified. Defensible.</div>
              </div>
            </div>
            <div class="visual-card vc-mid">
              <div class="vc-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              </div>
              <div class="vc-content">
                <div class="vc-label">PIP Coverage Accepted</div>
                <div class="vc-sub">Florida No-Fault · Major Auto Carriers</div>
                <div class="vc-pills">
                  <span>PIP</span>
                  <span>Auto Insurance</span>
                  <span>Attorney Cases</span>
                </div>
              </div>
            </div>
            <div class="visual-card vc-bot">
              <div class="vc-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </div>
              <div class="vc-content">
                <div class="vc-label">Same-Day Available</div>
                <div class="vc-sub">Mon – Fri · 10–1 and 3–6</div>
                <div class="vc-locations">
                  <div class="vc-loc"><span class="vc-dot"></span>Tamarac (954) 606-NECK</div>
                  <div class="vc-loc"><span class="vc-dot"></span>Port Saint Lucie (772) 333-2648</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="section section-teal" id="how">
    <div class="section-inner">
      <div class="section-header reveal">
        <div class="eyebrow eyebrow-light">What to Expect</div>
        <h2 class="light">From your first call<br/>to your first visit.</h2>
      </div>
      <div class="steps">
        <div class="step reveal">
          <div class="step-num">01</div>
          <h3>Call Us — Any Time</h3>
          <p>Call either location. We answer after hours. Tell us what happened and we'll get you scheduled — often same day.</p>
        </div>
        <div class="step-connector"></div>
        <div class="step reveal">
          <div class="step-num">02</div>
          <h3>Initial Evaluation</h3>
          <p>Your chiropractic physician will perform a thorough clinical evaluation, review your accident history, and order imaging if clinically indicated.</p>
        </div>
        <div class="step-connector"></div>
        <div class="step reveal">
          <div class="step-num">03</div>
          <h3>Treatment Plan</h3>
          <p>Based on clinical findings, your treating chiropractor will develop an individualized plan of care and explain your options.</p>
        </div>
        <div class="step-connector"></div>
        <div class="step reveal">
          <div class="step-num">04</div>
          <h3>Ongoing Care & Records</h3>
          <p>We provide ongoing treatment as indicated and maintain thorough clinical records. Medical records are available to you and, upon authorization, to your attorney.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- LOCATIONS -->
  <section class="section" id="locations">
    <div class="section-inner">
      <div class="section-header reveal">
        <div class="eyebrow">Our Locations</div>
        <h2>Two chiropractic clinic locations<br/>serving South Florida.</h2>
      </div>
      <div class="locations-grid">
        <div class="location-card reveal">
          <div class="location-badge">Broward County</div>
          <h3>Tamarac</h3>
          <p class="location-provider">Dr. Brian Wilner, D.C.</p>
          <address>
            5715 N. University Dr.<br/>
            Tamarac, FL 33321
          </address>
          <p class="location-feature">✓ On-site digital X-ray</p>
          <div class="location-hours">
            <div class="hours-row"><span>Mon – Fri</span><span>10:00 AM – 1:00 PM</span></div>
            <div class="hours-row"><span>Mon – Fri</span><span>3:00 PM – 6:00 PM</span></div>
            <div class="hours-row"><span>Saturday – Sunday</span><span>Closed</span></div>
          </div>
          <div class="location-actions">
            <a href="tel:+19546066325" class="btn-primary">(954) 606-NECK</a>
            <a href="https://maps.google.com/?q=5715+N+University+Dr+Tamarac+FL+33321" target="_blank" rel="noopener" class="btn-outline">Get Directions</a>
          </div>
        </div>
        <div class="location-card reveal">
          <div class="location-badge location-badge-gold">St. Lucie County</div>
          <h3>Port Saint Lucie</h3>
          <p class="location-provider">Dr. Kelly Kane, D.C.</p>
          <address>
            1700 SE Hillmoor Dr., Suite 502<br/>
            Port Saint Lucie, FL 34952
          </address>
          <div class="location-hours">
            <div class="hours-row"><span>Mon – Fri</span><span>10:00 AM – 1:00 PM</span></div>
            <div class="hours-row"><span>Mon – Fri</span><span>3:00 PM – 6:00 PM</span></div>
            <div class="hours-row"><span>Saturday – Sunday</span><span>Closed</span></div>
          </div>
          <div class="location-actions">
            <a href="tel:+17723332648" class="btn-primary">(772) 333-2648</a>
            <a href="https://maps.google.com/?q=1700+SE+Hillmoor+Dr+Suite+502+Port+Saint+Lucie+FL+34952" target="_blank" rel="noopener" class="btn-outline">Get Directions</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section-offwhite" id="faq">
    <div class="section-inner">
      <div class="section-header reveal">
        <div class="eyebrow">Frequently Asked Questions</div>
        <h2>Common questions from<br/>our patients.</h2>
      </div>
      <div class="faq-list">
        
        <details class="faq-item reveal">
          <summary>What is Florida's PIP insurance and what does it cover?</summary>
          <p>Florida's Personal Injury Protection (PIP) insurance, governed by §627.736 F.S., is a no-fault coverage that may pay a portion of medical expenses and lost wages following an auto accident, regardless of fault. PIP benefit availability depends on your individual policy terms, coverage limits, and other factors. We recommend contacting your insurer or attorney directly for specific coverage information. Chiropractic services are among the covered services under Florida PIP when rendered by a licensed chiropractic physician.</p>
        </details>
        <details class="faq-item reveal">
          <summary>Why is prompt evaluation important after an accident?</summary>
          <p>Under §627.736 F.S., Florida PIP benefits may require that you receive initial medical treatment within 14 days of your accident date. Missing this window may affect your eligibility for certain PIP benefits. This is an informational statement only — your actual coverage rights and obligations depend on your specific policy. Consult your attorney or insurer for guidance applicable to your situation.</p>
        </details>
        <details class="faq-item reveal">
          <summary>What types of injuries do chiropractors evaluate and treat?</summary>
          <p>Chiropractic physicians evaluate and treat conditions of the spine, muscles, and joints — including neck pain, back pain, disc injuries, whiplash, headaches, sciatica, and soft tissue injuries from accidents or chronic strain. If your condition requires care outside the scope of chiropractic, we will let you know and help coordinate a referral.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-section" id="book">
    <div class="section-inner">
      <div class="cta-block reveal">
        <div class="cta-left">
          <img src="/logo.png" alt="South Florida Injury Centers — Chiropractic Physicians" class="cta-logo" />
          <h2>Call now. We'll answer.<br/>Even after hours.</h2>
          <p>Dr. Wilner has been answering calls and treating patients since 2000. Call either location — we pick up after hours. Same-day appointments available at both locations.</p>
        </div>
        <div class="cta-right">
          <a href="tel:+19546066325" class="btn-primary btn-large">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.59 1.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6.09 6.09l1.18-1.18a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            (954) 606-NECK — Tamarac
          </a>
          <a href="tel:+17723332648" class="btn-primary btn-large btn-teal-outline">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.59 1.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6.09 6.09l1.18-1.18a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            (772) 333-2648 — Port Saint Lucie
          </a>
          <p class="cta-note">Same-day appointments available subject to clinical schedule</p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    background: var(--navy);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    padding-top: 70px;
  }
  .hero-bg-wave {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 70% 50%, rgba(27,175,196,0.12) 0%, transparent 70%),
      radial-gradient(ellipse 40% 40% at 90% 10%, rgba(201,162,39,0.08) 0%, transparent 60%);
    pointer-events: none;
  }
  .hero-inner {
    position: relative; z-index: 1;
    max-width: 1200px; margin: 0 auto;
    padding: 60px 40px 80px;
    display: grid; grid-template-columns: 1fr 400px;
    gap: 64px; align-items: center; width: 100%;
  }
  .hero-eyebrow {
    font-size: 0.72rem; font-weight: 600; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--teal-light); margin-bottom: 18px;
  }
  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(3.2rem, 6vw, 5.2rem);
    font-weight: 800; line-height: 0.96;
    color: var(--white); letter-spacing: -0.01em; margin-bottom: 16px;
  }
  .hero-accent {
    background: var(--grad-teal);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .hero-tagline-badge {
    display: inline-block; font-size: 0.68rem; font-weight: 700;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 20px;
  }
  .hero-sub {
    font-size: 1rem; color: rgba(255,255,255,0.62);
    max-width: 500px; line-height: 1.8; margin-bottom: 32px;
  }
  .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 40px; }
  .hero-trust { display: flex; align-items: center; gap: 20px; flex-wrap: wrap; }
  .trust-item { display: flex; flex-direction: column; gap: 2px; }
  .trust-item strong {
    font-family: var(--font-display); font-size: 1rem;
    font-weight: 700; color: var(--teal-light);
  }
  .trust-item span {
    font-size: 0.62rem; text-transform: uppercase;
    letter-spacing: 0.08em; color: rgba(255,255,255,0.35);
  }
  .trust-divider { width: 1px; height: 32px; background: rgba(255,255,255,0.12); }

  /* HERO CARD */
  .hero-card {
    background: rgba(255,255,255,0.04);
